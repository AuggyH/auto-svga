{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/svga-avatar-frame/project.schema.json",
  "title": "Avatar Frame Intermediate Project",
  "description": "Intermediate project format generated by the MVP before real SVGA binary export.",
  "$comment": "This schema is intentionally exporter-friendly: layers and timeline can be mapped to SVGA sprites and keyframes later.",
  "type": "object",
  "required": ["schemaVersion", "assetType", "name", "canvas", "assets", "layers", "timeline", "metadata"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "0.1.0" },
    "assetType": { "const": "avatar_frame" },
    "name": { "type": "string" },
    "canvas": {
      "type": "object",
      "required": ["width", "height", "fps", "durationMs"],
      "additionalProperties": false,
      "properties": {
        "width": { "type": "integer" },
        "height": { "type": "integer" },
        "fps": { "type": "integer" },
        "durationMs": { "type": "integer" }
      }
    },
    "assets": {
      "type": "array",
      "description": "Generated or copied asset references used by layers.",
      "items": {
        "type": "object",
        "required": ["id", "type", "path"],
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["image"] },
          "path": { "type": "string" },
          "width": { "type": "integer" },
          "height": { "type": "integer" },
          "sha256": { "type": "string" }
        }
      }
    },
    "layers": {
      "type": "array",
      "description": "Logical animation layers. A future SVGA exporter can map these to sprites.",
      "items": {
        "type": "object",
        "required": ["id", "type", "blendMode", "keyframes"],
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["image", "effect"] },
          "assetId": { "type": "string" },
          "blendMode": { "enum": ["normal", "screen", "add"] },
          "keyframes": { "type": "array" }
        }
      }
    },
    "timeline": {
      "type": "object",
      "required": ["frameCount", "loop"],
      "properties": {
        "frameCount": { "type": "integer" },
        "loop": { "type": "boolean" }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["generatedAt", "templates"],
      "properties": {
        "generatedAt": { "type": "string" },
        "templates": { "type": "array" }
      }
    }
  }
}
