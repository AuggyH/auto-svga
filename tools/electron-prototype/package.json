{
  "name": "auto-svga-electron-prototype",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Isolated Auto SVGA desktop runtime prototype",
  "main": "main.cjs",
  "license": "UNLICENSED",
  "scripts": {
    "spike:electron:prepare": "npm --prefix ../.. run build && node scripts/prepare-runtime.mjs",
    "spike:electron:test": "npm run spike:electron:prepare && node --test tests/*.test.mjs",
    "spike:electron:smoke": "npm run spike:electron:prepare && electron . --smoke",
    "spike:electron:package:mac": "npm run spike:electron:prepare && electron-packager . AutoSVGAPrototype --platform=darwin --arch=arm64 --out=.artifacts --overwrite --prune=true --asar --ignore='^/(tests|scripts|\\.artifacts)($|/)'",
    "spike:electron:package:win": "npm run spike:electron:prepare && electron-packager . AutoSVGAPrototype --platform=win32 --arch=x64 --out=.artifacts --overwrite --prune=true --asar --ignore='^/(tests|scripts|\\.artifacts)($|/)'"
  },
  "dependencies": {
    "fast-png": "8.0.0",
    "protobufjs": "8.6.6"
  },
  "devDependencies": {
    "@electron/packager": "20.0.1",
    "electron": "42.4.1"
  }
}
