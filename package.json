{
  "name": "svga-avatar-frame-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "MVP CLI for generating intermediate SVGA-like avatar frame animation projects.",
  "type": "module",
  "bin": {
    "svga-avatar-frame": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "npm run test:all",
    "autosvga:plan": "tsx src/cli.ts plan",
    "autosvga:preview": "tsx src/cli.ts preview",
    "autosvga:report": "tsx src/cli.ts report",
    "autosvga:export": "tsx src/cli.ts export",
    "autosvga:package": "tsx src/cli.ts package",
    "autosvga:accept": "tsx src/cli.ts accept",
    "test:all": "tsc -p tsconfig.json && node --test dist/tests/*.test.js",
    "test:mvp": "tsc -p tsconfig.json && node --test dist/tests/mvp-planner.test.js",
    "loop:validate": "node tools/loop-validate.mjs",
    "loop:handoff": "node tools/loop-handoff.mjs",
    "validate:example": "tsc -p tsconfig.json && node dist/cli.js validate examples/avatar_frame_basic",
    "build:example": "tsc -p tsconfig.json && node dist/cli.js build examples/avatar_frame_basic",
    "export:example": "tsc -p tsconfig.json && node dist/cli.js export examples/avatar_frame_basic",
    "preview:player": "node tools/svga-player-preview/server.mjs",
    "local:preview": "node tools/launch-local-preview.mjs",
    "desktop:dev": "npm --prefix tools/electron-prototype/experiments/svga-web run desktop:dev",
    "desktop:smoke": "npm --prefix tools/electron-prototype/experiments/svga-web run desktop:smoke",
    "desktop:p2:normal-proof": "npm --prefix tools/electron-prototype/experiments/svga-web run desktop:p2:normal-proof",
    "desktop:short-term:acceptance-matrix": "npm --prefix tools/electron-prototype/experiments/svga-web run desktop:short-term:acceptance-matrix",
    "desktop:short-term:design-system-check": "npm --prefix tools/electron-prototype/experiments/svga-web run desktop:short-term:design-system-check",
    "desktop:p2:web-reference": "npm --prefix tools/electron-prototype/experiments/svga-web run desktop:p2:web-reference",
    "desktop:p2:parity-report": "npm --prefix tools/electron-prototype/experiments/svga-web run desktop:p2:parity-report",
    "desktop:p2:reviewer-b": "npm --prefix tools/electron-prototype/experiments/svga-web run desktop:p2:reviewer-b",
    "desktop:p2:upload-package": "npm --prefix tools/electron-prototype/experiments/svga-web run desktop:p2:upload-package",
    "desktop:p3:upload-package": "npm --prefix tools/electron-prototype/experiments/svga-web run desktop:p3:upload-package",
    "desktop:p4:upload-package": "npm --prefix tools/electron-prototype/experiments/svga-web run desktop:p4:upload-package",
    "desktop:p5:live-smoke": "npm run build && npm --prefix tools/electron-prototype/experiments/svga-web run desktop:p5:live-smoke",
    "p5:reports": "npm run desktop:p5:live-smoke",
    "nq1:fixture-matrix": "npm run build && node tools/nq1/generate-fixture-matrix.mjs",
    "nq1:model-history": "npm run build && node tools/nq1/generate-model-history-report.mjs",
    "nq1:async-race": "npm run build && node tools/nq1/generate-async-race-report.mjs",
    "nq1:round-trip-matrix": "npm run build && node tools/nq1/generate-round-trip-matrix-report.mjs",
    "nq1:save-as-safety": "npm run build && node tools/nq1/generate-save-as-safety-report.mjs",
    "nq1:cleanup-stress": "npm run build && node tools/nq1/generate-cleanup-stress-report.mjs",
    "nq1:performance-baseline": "npm run build && node tools/nq1/generate-performance-baseline-report.mjs",
    "nq1:accessibility-audit": "npm run build && node tools/nq1/generate-accessibility-audit-report.mjs",
    "nq1:flake-stability": "npm run build && node tools/nq1/generate-flake-stability-report.mjs",
    "nq1-r1:reports": "npm run build && node tools/nq1-r1/generate-reports.mjs",
    "svga-workbench:v1:validate": "node tools/svga-workbench/run-validation-suite.mjs",
    "svga-workbench:v1:complete-review": "node tools/svga-workbench/complete-review-package.mjs",
    "svga-workbench:v1:distribution-readiness": "node tools/svga-workbench/distribution-readiness.mjs",
    "svga-workbench:real-assets": "npm run build && node tools/svga-workbench/real-asset-validation-matrix.mjs"
  },
  "dependencies": {
    "fast-png": "8.0.0",
    "protobufjs": "^8.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@9.12.0"
}
